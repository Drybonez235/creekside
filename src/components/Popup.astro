---
/* Revised Popup: Fixed interaction blocking and iframe dynamic calculation */
---

<div
  id="profit-popup-overlay"
  class="fixed inset-0 z-100 hidden items-start md:items-center justify-center bg-primary-900/60 opacity-0 transition-opacity duration-500 backdrop-blur-xs overflow-y-auto p-4"
  role="dialog"
  aria-modal="true"
>
  <div
    id="profit-popup-content"
    class="relative my-auto w-full max-w-2xl overflow-hidden rounded-xl bg-grey-50 shadow-2xl transition-transform duration-500 scale-95"
  >
    <button
      id="close-popup"
      class="absolute top-4 right-4 z-20 size-11 flex items-center justify-center rounded-full bg-grey-100 text-grey-600 hover:bg-grey-200 hover:text-primary-900 transition-colors cursor-pointer"
      aria-label="Close popup"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="size-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        />
      </svg>
    </button>

    <div class="p-2 md:p-4 pt-14 md:pt-4">
      <div class="relative w-full h-[776px] block">
        <iframe
          src="https://api.msglink.cloud/widget/form/8As7Tl468YopNi5PJw9G"
          id="inline-8As7Tl468YopNi5PJw9G"
          class="w-full h-full border-none rounded-xs"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="deactivateAfter"
          data-deactivation-value="2"
          data-form-name="Lead Magnet Client"
          data-height="776"
          data-layout-iframe-id="inline-8As7Tl468YopNi5PJw9G"
          data-form-id="8As7Tl468YopNi5PJw9G"
          title="Lead Magnet Client"
        >
        </iframe>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .ep-iFrameContainer, 
  .ep-wrapper {
    width: 100% !important;
    height: 100% !important;
  }
</style>

<script src="https://api.msglink.cloud/js/form_embed.js" is:inline></script>

<script>
  const setupPopup = () => {
    const overlay = document.getElementById("profit-popup-overlay");
    const content = document.getElementById("profit-popup-content");
    const closeBtn = document.getElementById("close-popup");
    const DISMISS_KEY = "popup_dismiss_count";
    let shownOnThisPage = false;

    const getDismissCount = () => {
      return parseInt(sessionStorage.getItem(DISMISS_KEY) || "0", 10);
    };

    const incrementDismiss = () => {
      const count = getDismissCount() + 1;
      sessionStorage.setItem(DISMISS_KEY, String(count));
      return count;
    };

    const showPopup = () => {
      if (shownOnThisPage) return;
      if (getDismissCount() >= 2) return;

      shownOnThisPage = true;
      
      // 1. Safe change back to display: hidden pattern to clear layout positioning overhead
      overlay?.classList.remove("hidden");
      overlay?.classList.add("flex");

      // 2. Force custom runtime event dispatch loop so the widget container initializes perfectly while visible
      window.dispatchEvent(new Event('resize'));

      setTimeout(() => {
        overlay?.classList.add("opacity-100");
        content?.classList.remove("scale-95");
        content?.classList.add("scale-100");
        
        // Secondary recalculation verification pass after the transition scales execute
        window.dispatchEvent(new Event('resize'));
      }, 10);

      document.body.style.overflow = "hidden";
    };

    const hidePopup = () => {
      overlay?.classList.remove("opacity-100");
      content?.classList.add("scale-95");
      content?.classList.remove("scale-100");

      setTimeout(() => {
        overlay?.classList.add("hidden");
        overlay?.classList.remove("flex");
      }, 500);

      document.body.style.overflow = "";
      incrementDismiss();
    };

    if (getDismissCount() < 2) {
      setTimeout(showPopup, 15000);
    }

    closeBtn?.addEventListener("click", hidePopup);
    overlay?.addEventListener("click", (e) => {
      if (e.target === overlay) hidePopup();
    });
  };

  setupPopup();
  document.addEventListener("astro:after-swap", setupPopup);
</script>