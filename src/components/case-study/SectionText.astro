---
import { creeksideTheme } from '../../data/caseStudyTheme';

interface Props {
  sectionLabel?: string;
  heading?: string;
  paragraphs?: string[];
  tags?: string[];
}

const { sectionLabel, heading, paragraphs = [], tags = [] } = Astro.props;
const t = creeksideTheme;
---

<div>
  {sectionLabel && (
    <span
      class="mb-2.5 inline-block text-[0.65rem] font-bold uppercase tracking-[2.5px]"
      style={`color: ${t.accentColor}`}
    >
      {sectionLabel}
    </span>
  )}

  {heading && (
    <h2 class="mb-4 text-[1.6rem] font-bold tracking-tight" style="color: #1a1a2e">
      {heading}
    </h2>
  )}

  {paragraphs.map((p) => (
    <p class="mb-3.5 text-[0.95rem] leading-[1.8] text-gray-600 last:mb-0">
      {p}
    </p>
  ))}

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="inline-block rounded-full border border-gray-200 bg-gray-100 px-3.5 py-1 text-[0.72rem] font-semibold tracking-wide text-gray-600">
          {tag}
        </span>
      ))}
    </div>
  )}
</div>
