---
import { creeksideTheme } from '../../data/caseStudyTheme';

interface Props {
  heroBadge: string;
  heroTitle: string;
  clientName: string;
  heroSubtitle: string;
}

const { heroBadge, heroTitle, clientName, heroSubtitle } = Astro.props;
const t = creeksideTheme;

// Split title on {CLIENT} placeholder to insert highlighted client name
const titleParts = heroTitle.includes('{CLIENT}')
  ? heroTitle.split('{CLIENT}')
  : [heroTitle, ''];
---

<div
  class="relative overflow-hidden px-8 pt-14 pb-12 md:px-14"
  style={`background: ${t.heroGradient}`}
>
  <!-- Decorative glow -->
  <div
    class="absolute -top-1/2 -right-1/5 h-[500px] w-[500px] rounded-full"
    style={`background: radial-gradient(circle, ${t.accentGlow} 0%, transparent 70%)`}
  ></div>
  <div
    class="absolute -bottom-1/3 -left-1/10 h-[400px] w-[400px] rounded-full"
    style="background: radial-gradient(circle, rgba(15,52,96,0.2) 0%, transparent 70%)"
  ></div>

  <div class="relative z-10">
    <span
      class="mb-5 inline-block rounded-full px-4 py-1.5 text-[0.7rem] font-bold uppercase tracking-[2px]"
      style={`background: ${t.badgeBg}; border: 1px solid ${t.badgeBorder}; color: ${t.badgeText}`}
    >
      {heroBadge}
    </span>

    <h1 class="mb-3 text-3xl font-extrabold leading-[1.15] tracking-tight text-white sm:text-[2.6rem]">
      {titleParts[0]}<span style={`color: ${t.accentLight}`}>{clientName}</span>{titleParts[1]}
    </h1>

    <p class="max-w-[600px] text-lg font-light leading-relaxed" style="color: rgba(255,255,255,0.7)">
      {heroSubtitle}
    </p>
  </div>
</div>
