---
import Form from '../components/Form.astro'
---
<section id="freequote" class="relative py-20 lg:py-32 bg-white overflow-hidden">
  <div class="absolute inset-0 opacity-5 pointer-events-none"></div>

  <div class="container relative mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-24">
      
      <div class="relative">
        <div class="overflow-hidden rounded-sm shadow-sm border border-grey-100">
          <img 
            src="/laptop-with-marketing-charts.avif" 
            alt="Laptop with marketing charts and data analytics" 
            class="w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -top-4 -right-4 size-24 bg-secondary-500/10 -z-10 rounded-xs"></div>
      </div>

      <div class="max-w-xl">
        <h2 class="text-4xl/tight font-extrabold tracking-tight text-primary-900 md:text-5xl/tight uppercase">
          Schedule your <br>
          <span class="text-secondary-500">free consultation!</span>
        </h2>
        
        <p class="mt-6 text-lg/8 text-grey-600">
          Ready to stop hemorrhaging money on inefficient ads? Click below to book your call. After choosing a date and time, you'll receive an email confirmation and our $10K Profit Recovery Audit checklist.
        </p>
        <Form idPrefix="Scheduleconsultation"/>

        <!-- Calendly popup: opens scheduling overlay on button click -->
        <div class="mt-10 flex flex-col items-center gap-6 sm:flex-row sm:items-start">
          <button
            id="calendly-popup-btn"
            type="button"
            class="inline-flex items-center justify-center gap-3 rounded-sm bg-secondary-500 px-8 py-4 text-lg font-bold uppercase tracking-wider text-white shadow-sm transition-all hover:bg-secondary-600 hover:shadow-md hover:translate-y-[-2px] active:scale-95"
          >
            <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Book Your Strategy Call
          </button>
          <noscript>
            <a
              href="https://calendly.com/creekside_marketing/creekside-marketing-strategy-call"
              class="inline-flex items-center justify-center px-8 py-4 bg-secondary-500 text-white font-bold uppercase tracking-wider rounded-sm"
            >Book Your Call Now</a>
          </noscript>
        </div>

        <div class="mt-6 flex flex-col sm:flex-row items-center gap-6">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-primary-900 uppercase">Risk-Free</span>
            <span class="text-xs text-grey-500">Includes $10K Profit Audit</span>
          </div>
        </div>

        <p class="mt-8 text-sm text-grey-500 italic border-l-2 border-secondary-500 pl-4">
          "The biggest risk you can take is not hopping on a call with us to explore how much more your campaigns could achieve."
        </p>

        <script>
          (function () {
            var btn = document.getElementById('calendly-popup-btn');
            if (!btn) return;

            var calendlyReady = false;

            function loadCalendlyScript(callback) {
              if (calendlyReady) { callback(); return; }

              var link = document.createElement('link');
              link.rel = 'stylesheet';
              link.href = 'https://assets.calendly.com/assets/external/widget.css';
              document.head.appendChild(link);

              var script = document.createElement('script');
              script.src = 'https://assets.calendly.com/assets/external/widget.js';
              script.onload = function () {
                calendlyReady = true;
                callback();
              };
              document.head.appendChild(script);
            }

            btn.addEventListener('click', function () {
              loadCalendlyScript(function () {
                Calendly.initPopupWidget({
                  url: 'https://calendly.com/creekside_marketing/creekside-marketing-strategy-call',
                });
              });
            });
          })();
        </script>
      </div>

    </div>
  </div>
</section>