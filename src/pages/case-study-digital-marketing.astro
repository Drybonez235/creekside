---
import Nav from '../components/Nav.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { creeksideTheme } from '../data/caseStudyTheme';
import { getCollection } from 'astro:content';

const allStudies = await getCollection('case-studies');
const caseStudies = allStudies.map(study => ({
  slug: study.slug,
  ...study.data
}));

// Put featured study first, then sort rest alphabetically
const featured = caseStudies.find(s => s.featured) || caseStudies[0];
const rest = caseStudies.filter(s => s.slug !== featured.slug);

const t = creeksideTheme;

const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Creekside Marketing Success Stories",
  "description": "A collection of digital marketing case studies showing ROAS and revenue growth.",
  "url": "https://creeksidemarketingpros.com/case-study-digital-marketing/",
  "numberOfItems": caseStudies.length,
  "itemListElement": caseStudies.map((study, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "CreativeWork",
      "name": study.title,
      "description": study.summary,
      "url": `https://creeksidemarketingpros.com/case-study-digital-marketing/${study.slug}`,
      "headline": study.title,
      "author": {
        "@type": "Organization",
        "name": "Creekside Marketing"
      }
    }
  })),
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://creeksidemarketingpros.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Case Studies",
        "item": "https://creeksidemarketingpros.com/case-study-digital-marketing/"
      },
    ]
  }
};

import '../styles/global.css';
---
<Layout
  title="Case Study: Digital Marketing - Creekside Marketing"
  description="Proof is in the profit. Explore our real-world case studies showing 37%+ ROAS improvements, doubled revenue, and scaled ad accounts for law firms, dental practices, and e-commerce brands."
  canonicalURL="https://creeksidemarketingpros.com/case-study-digital-marketing/"
  schema={listSchema}
>
  <Nav />

  <main class="min-h-dvh bg-grey-50">
    <!-- Hero header with gradient -->
    <div class="relative overflow-hidden px-4 py-20 lg:px-12" style={`background: ${t.heroGradient}`}>
      <div class="absolute -top-1/2 -right-1/5 h-[500px] w-[500px] rounded-full" style={`background: radial-gradient(circle, ${t.accentGlow} 0%, transparent 70%)`}></div>
      <div class="mx-auto max-w-7xl relative z-10">
        <span class="mb-4 inline-block rounded-full px-4 py-1.5 text-[0.7rem] font-bold uppercase tracking-[2px]" style={`background: ${t.badgeBg}; border: 1px solid ${t.badgeBorder}; color: ${t.badgeText}`}>
          Client Results
        </span>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl/tight">
          The Creekside Difference
        </h1>
        <p class="mt-3 max-w-2xl text-lg font-light leading-relaxed" style="color: rgba(255,255,255,0.7)">
          Proven strategies that increase ROAS and make a tangible difference to your business trajectory.
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 py-12 lg:px-12">

      <!-- Featured Study -->
      <section class="mb-12 overflow-hidden rounded-2xl bg-white shadow-lg">
        <div class="lg:flex">
          <div class="flex shrink-0 items-center justify-center p-12 lg:w-1/3" style={`background: ${t.heroGradient}`}>
            {featured.logo ? (
              <img
                src={featured.logo}
                alt={featured["logo-alt"]}
                class="max-h-32 w-auto object-contain"
              />
            ) : (
              <div class="flex size-48 items-center justify-center rounded-full border border-white/20 bg-white/10">
                <span class="font-bold italic text-white/50">Logo Pending</span>
              </div>
            )}
          </div>

          <div class="flex flex-col justify-center p-8 lg:p-12">
            <span class="text-[0.65rem] font-bold uppercase tracking-[2.5px]" style={`color: ${t.accentColor}`}>
              {featured.category}
            </span>
            <h2 class="mt-3 text-2xl font-bold text-primary-900 sm:text-3xl/10">
              {featured.title}
            </h2>
            <p class="mt-4 max-w-xl text-base leading-relaxed text-grey-600">
              {featured.summary}
            </p>
            <div class="mt-6 flex items-center gap-6">
              <div>
                <div class="text-2xl font-extrabold" style={`color: ${t.accentColor}`}>{featured.metrics.roas}</div>
                <div class="text-[0.65rem] font-semibold uppercase tracking-[1.5px] text-gray-400">Primary Result</div>
              </div>
              <div>
                <div class="text-2xl font-extrabold text-primary-900">{featured.metrics.scale}</div>
                <div class="text-[0.65rem] font-semibold uppercase tracking-[1.5px] text-gray-400">Scale</div>
              </div>
            </div>
            <div class="mt-8">
              <a href={`/case-study-digital-marketing/${featured.slug}/`} class="inline-block rounded-lg bg-secondary-500 px-8 py-3.5 text-sm font-bold text-white transition-colors hover:bg-secondary-400">
                View Full Case Study
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Case Study Grid -->
      <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map((study) => (
          <a href={`/case-study-digital-marketing/${study.slug}/`} class="group flex flex-col overflow-hidden rounded-xl border border-grey-200 bg-white shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <!-- Card accent bar -->
            <div class="h-1" style={`background: ${t.heroGradient}`}></div>

            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-3">
                {study.logo && <img src={study.logo} alt={study["logo-alt"]} class="size-8 object-contain" />}
                <span class="text-[0.65rem] font-bold uppercase tracking-[2px]" style={`color: ${t.accentColor}`}>
                  {study.category}
                </span>
              </div>

              <h3 class="mt-4 text-lg font-bold leading-snug text-primary-900 transition-colors group-hover:text-secondary-500">
                {study.title}
              </h3>

              <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-grey-500">
                {study.summary}
              </p>

              <!-- Metrics preview -->
              <div class="mt-auto flex items-center gap-6 border-t border-grey-100 pt-4 mt-6">
                <div>
                  <div class="text-xl font-extrabold" style={`color: ${t.accentColor}`}>{study.metrics.roas}</div>
                  <div class="text-[0.6rem] font-semibold uppercase tracking-[1.5px] text-gray-400">Result</div>
                </div>
                <div>
                  <div class="text-xl font-extrabold text-primary-900">{study.metrics.scale}</div>
                  <div class="text-[0.6rem] font-semibold uppercase tracking-[1.5px] text-gray-400">Scale</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </section>
    </div>
  </main>

  <Footer />
</Layout>
